---
import Container from "@ui/Container.astro";
import Button from "@ui/Button.astro";
import type { Translations } from "@data/i18n";

interface Props {
  content: Translations["cta"];
  bookingUrl: string;
  email: string;
}

const { content, bookingUrl, email } = Astro.props;
---

<section class="relative py-20 sm:py-28">
  <!-- Gradient orb -->
  <div
    class="pointer-events-none absolute bottom-0 left-1/2 -z-10 h-[500px] w-[700px] -translate-x-1/2 translate-y-1/3 rounded-full bg-electric/5 blur-3xl"
  ></div>

  <Container>
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-3xl font-semibold text-snow sm:text-4xl lg:text-5xl leading-tight">
        {content.headline}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-steel">
        {content.description}
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href={bookingUrl} size="lg">
          {content.primaryCta}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button href={`mailto:${email}`} variant="secondary" size="lg">
          {content.secondaryCta}
        </Button>
      </div>

      <p class="mt-6 text-sm text-steel">
        {content.below}{" "}
        <a
          href={`mailto:${email}`}
          class="text-electric hover:text-electric-light transition-colors"
        >
          {email}
        </a>
      </p>
    </div>
  </Container>
</section>

---
import Container from "@ui/Container.astro";
import SectionHeading from "@ui/SectionHeading.astro";
import { testimonials } from "@data/site";
---

<section class="relative py-20 sm:py-28">
  <div class="absolute inset-0 -z-10 bg-navy/30"></div>

  <Container>
    <div class="reveal">
      <SectionHeading label="Trusted By" title="What our clients say" />
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="reveal rounded-xl border border-slate-custom bg-navy p-6 sm:p-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="mb-4 h-8 w-8 text-electric/30" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <blockquote class="text-sm leading-relaxed text-silver">
            "{t.quote}"
          </blockquote>
          <div class="mt-6 border-t border-slate-custom pt-4">
            <p class="text-sm font-medium text-snow">{t.author}</p>
            <p class="text-xs text-steel">{t.company}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

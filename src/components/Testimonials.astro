---
import Container from "@ui/Container.astro";
import SectionHeading from "@ui/SectionHeading.astro";
import type { Translations } from "@data/i18n";

interface Props {
  content: Translations["audience"];
}

const { content } = Astro.props;
---

<section class="relative py-20 sm:py-28">
  <div class="absolute inset-0 -z-10 bg-navy/30"></div>

  <Container>
    <div class="reveal">
      <SectionHeading
        label={content.label}
        title={content.headline}
      />
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {content.items.map((item) => (
        <div class="reveal rounded-xl border border-slate-custom bg-navy p-6 sm:p-8 transition-all duration-300 hover:border-electric/30">
          <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-electric/10">
            {item.icon === "target" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" />
              </svg>
            )}
            {item.icon === "shield" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            )}
            {item.icon === "briefcase" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />
              </svg>
            )}
          </div>
          <h3 class="font-serif text-xl font-semibold text-snow">{item.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-steel">{item.description}</p>
        </div>
      ))}
    </div>
  </Container>
</section>

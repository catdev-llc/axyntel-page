---
import Container from "@ui/Container.astro";
import { siteConfig } from "@data/site";
---

<footer class="border-t border-slate-custom py-10">
  <Container>
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <!-- Logo + copyright -->
      <div class="flex items-center gap-6">
        <a href="/" class="font-serif text-lg font-semibold text-snow">
          axyntel<span class="text-electric">.</span>
        </a>
        <span class="text-sm text-steel">
          &copy; 2026 Axyntel. All rights reserved.
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a
          href={`mailto:${siteConfig.email}`}
          class="text-sm text-steel transition-colors hover:text-snow"
        >
          Contact
        </a>
        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-steel transition-colors hover:text-snow"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </Container>
</footer>

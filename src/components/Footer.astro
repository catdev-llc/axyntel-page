---
import Container from "@ui/Container.astro";
import type { Translations, Locale } from "@data/i18n";
import { getLocalePath } from "@data/i18n";

interface Props {
  content: Translations["footer"];
  locale: Locale;
  email: string;
  linkedin: string;
}

const { content, locale, email, linkedin } = Astro.props;
const homePath = getLocalePath(locale);
---

<footer class="border-t border-slate-custom py-10">
  <Container>
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <!-- Logo + copyright -->
      <div class="flex items-center gap-6">
        <a href={homePath} class="font-serif text-lg font-semibold text-snow">
          axyntel<span class="text-electric">.</span>
        </a>
        <span class="text-sm text-steel">
          {content.copyright}
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a
          href={`mailto:${email}`}
          class="text-sm text-steel transition-colors hover:text-snow"
        >
          {content.contact}
        </a>
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-steel transition-colors hover:text-snow"
        >
          {content.linkedin}
        </a>
      </div>
    </div>
  </Container>
</footer>

---
import "@/styles/global.css";
import type { Locale } from "@data/i18n";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const {
  title = "Axyntel — Research Intelligence for B2B Decisions",
  description = "Structured, fully-cited intelligence reports for competitive strategy, regulatory compliance, and investment decisions. Delivered in days, not months.",
  locale = "en",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = "https://axyntel.com";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="en" href={`${siteOrigin}/`} />
    <link rel="alternate" hreflang="de" href={`${siteOrigin}/de/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteOrigin}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Axyntel" />
    <meta property="og:locale" content={locale === "de" ? "de_DE" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <!-- Intersection Observer for reveal animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
      );

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
